{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yap",
  "version": "0.1.0",
  "identifier": "com.yap.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Yap",
        "width": 550,
        "height": 650,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      },
      {
        "label": "pill",
        "url": "pill.html",
        "title": "",
        "width": 260,
        "height": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
